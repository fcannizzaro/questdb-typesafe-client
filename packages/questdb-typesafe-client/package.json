{
  "name": "@fcannizzaro/questdb-typesafe-client",
  "version": "1.0.0",
  "description": "Type-safe QuestDB client library for TypeScript",
  "author": "Francesco Cannizzaro (https://github.com/fcannizzaro)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fcannizzaro/questdb-typesafe.git",
    "directory": "packages/questdb-typesafe-client"
  },
  "homepage": "https://github.com/fcannizzaro/questdb-typesafe#readme",
  "bugs": {
    "url": "https://github.com/fcannizzaro/questdb-typesafe/issues"
  },
  "keywords": [
    "questdb",
    "typesafe",
    "typescript",
    "query-builder",
    "sql",
    "timeseries",
    "database"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/questdb-typesafe-client.umd.cjs",
  "module": "./dist/questdb-typesafe-client.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/questdb-typesafe-client.js",
      "require": "./dist/questdb-typesafe-client.umd.cjs"
    }
  },
  "scripts": {
    "dev": "bun vite dev",
    "build": "bun vite build",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "fmt": "oxfmt",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "typescript": "6.0.2",
    "zod": "^4.0.0"
  }
}
